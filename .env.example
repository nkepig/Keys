APP_NAME=Key Manager
DEBUG=false
DATABASE_URL=sqlite:///./keys.db
SECRET_KEY=your-secret-key-here
LOGIN_PASSWORD=your-password-here
FOFA_API_KEYS=[]

# SMTP（监控告警等）：不写则使用 app/config.py 内默认值；若在 .env 中填写则会覆盖。
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_RECIPIENTS=["2356357995@qq.com"]

# NEWAPI_AUTH_CACHE=1                    # 写入 data/newapi_auth_<base规范化>.json
# NEWAPI_AUTH_CACHE_TTL=3600             # 缓存秒数，超时重新登录

# scripts/newapi_site_monitor.py（cron）
# NEWAPI_MONITOR_URL=
# NEWAPI_MONITOR_USERNAME=
# NEWAPI_MONITOR_PASSWORD=

# 云雾 API（个人面板 · 供应商）
YUNWU_BASE_URL=https://gys.oljjio.click
YUNWU_USERNAME=
YUNWU_PASSWORD=
# YUNWU_GAP_PATH=/api/model-gaps                  # 模型实时缺口接口路径
# YUNWU_AUTH_CACHE=1                             # 写入 data/yunwu_auth_<host>.json
# YUNWU_AUTH_CACHE_TTL=3600                       # exp 解析失败时的回退缓存秒数
# YUNWU_AUTH_REFRESH_SKEW=60                      # 距过期还剩多少秒时提前刷新

# 管理员渠道推送（仅服务端使用，不要暴露到前端）
MSK_API_KEY=
# MSK_BASE_URL=https://gys.oljjio.click/openapi/v1
